<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/orderRowContainer"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#FFFFFF"
    android:padding="16dp"
    android:layout_marginBottom="12dp">

    <TextView
        android:id="@+id/orderIdTextView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Order #1001"
        android:textSize="12sp"
        android:textColor="#888888" />

    <TextView
        android:id="@+id/customerNameTextView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Sarah M."
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#111111"
        android:layout_marginTop="4dp" />

    <TextView
        android:id="@+id/statusTextView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="PENDING"
        android:textSize="14sp"
        android:textColor="#444444"
        android:layout_marginTop="8dp" />

    <TextView
        android:id="@+id/itemCountTextView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="3 items"
        android:textSize="14sp"
        android:textColor="#444444"
        android:layout_marginTop="4dp" />

    <TextView
        android:id="@+id/totalTextView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="$24.50"
        android:textSize="14sp"
        android:textColor="#444444"
        android:layout_marginTop="4dp" />

    <TextView
        android:id="@+id/priorityTextView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Priority"
        android:textSize="12sp"
        android:textStyle="bold"
        android:textColor="#B00020"
        android:layout_marginTop="8dp" />

    <Button
        android:id="@+id/advanceOrderButton"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:text="Advance Order"
        android:visibility="visible"
        android:enabled="true"
        android:backgroundTint="#008000"
        />

    <LinearLayout
        android:id="@+id/orderDetailsContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        android:layout_marginTop="12dp">

        <TextView
            android:id="@+id/itemsTitleTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Items:"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#111111" />

        <TextView
            android:id="@+id/itemsTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Burger\nFries\nCoke"
            android:textSize="14sp"
            android:textColor="#444444"
            android:layout_marginTop="4dp" />

    </LinearLayout>


</LinearLayout>

